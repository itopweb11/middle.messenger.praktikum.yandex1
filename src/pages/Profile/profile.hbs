<div>
    <form>
        {{> Input type="file" name="avatar" value=email id="avatarField" }}
        <span>{{display_name}}</span>
        <div>
            {{> Input type="text" name="email" value=email label="Почта" id="email_input" }}
            {{> Input type="text" name="login" value=login label="Логин" id="login_input" }}
            {{> Input type="text" name="first_name" value=first_name label="Имя" id="firstName_input" }}
            {{> Input type="text" name="second_name" value=second_name label="Фамилия" id="secondName_input" }}
            {{> Input type="text" name="display_name" value=display_name label="Имя в чате" id="chat_name_input" }}
            {{> Input type="text" name="phone" value=phone label="Телефон" id="phone_input" }}
        </div>
    </form>
    <div>
        {{> Link url='/src/pages/Profile/' text="Изменить данные" }}
        {{> Link url='/src/pages/Profile/' text="Изменить пароль" }}
        {{> Link url='/' text="Выйти" }}
    </div>
</div>